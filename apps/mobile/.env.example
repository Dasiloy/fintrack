# =============================================================================
# Mobile App (Expo) — Local Environment Variables Template
#
# Expo reads variables prefixed with EXPO_PUBLIC_ and injects them into the
# client bundle. Do NOT put secrets in EXPO_PUBLIC_ vars — they are visible
# to anyone who installs the app.
#
# Setup:
#   cp apps/mobile/.env.example apps/mobile/.env
# =============================================================================


# ── API Gateway URL ───────────────────────────────────────────────────────────
# Full URL of the API Gateway that the mobile app calls.
# For local development on a physical device, replace localhost with your
# machine's local network IP (e.g. http://192.168.1.x:4001).
# This can reference the root .env variable using dotenv-expand syntax.
EXPO_PUBLIC_API_URL=http://localhost:4001


# ── App Display Name ──────────────────────────────────────────────────────────
# The human-readable name shown in the Expo Go client and splash screen.
EXPO_PUBLIC_APP_NAME=FinTrack

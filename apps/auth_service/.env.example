# =============================================================================
# Auth Service — Local Environment Variables Template
#
# These vars are specific to the auth_service gRPC microservice.
# Shared vars (DATABASE_URL, REDIS_URL, etc.) live in the root .env file.
#
# Setup:
#   cp apps/auth_service/.env.example apps/auth_service/.env
# =============================================================================


# ── Service Identity ──────────────────────────────────────────────────────────
# Logical name for this microservice — used in logs and health checks.
MICROSERVICE_NAME=AUTH_SERVICE


# ── OTP JWT Secret & Expiration ───────────────────────────────────────────────
# Secret used to sign short-lived OTP / email-verification tokens.
# Generate with: openssl rand -base64 48
# Note: this can differ from the root JWT_OTP_SECRET to keep scopes isolated.
JWT_OTP_SECRET=your-auth-service-otp-secret-generate-with-openssl-rand-base64-48

# How long an OTP token is valid (ms/zeit format — e.g. 30m, 1h)
JWT_OTP_TOKEN_EXPIRATION=30m


# ── 2FA JWT Secret & Expiration ───────────────────────────────────────────────
# Secret used to sign the short-lived 2FA challenge token issued after the
# first step of login (before the user enters their TOTP code).
# Generate with: openssl rand -base64 48
JWT_2FA_SECRET=your-2fa-secret-generate-with-openssl-rand-base64-48

# How long the 2FA challenge token is valid
JWT_2FA_TOKEN_EXPIRATION=5m


# ── OTP Expiry ────────────────────────────────────────────────────────────────
# How long (minutes) an OTP code is valid before it expires.
# Should match the value in the root .env.
OTP_EXPIRY_MINUTES=5


# ── AES Encryption Key ────────────────────────────────────────────────────────
# 256-bit key used to encrypt sensitive data at rest (e.g. TOTP secrets).
# MUST be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
AES_KEY=your-64-hex-character-aes-key-generate-with-openssl-rand-hex-32

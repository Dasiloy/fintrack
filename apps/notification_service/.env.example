# =============================================================================
# Notification Service — Local Environment Variables Template
#
# These vars are specific to the notification_service gRPC microservice.
# Shared vars (DATABASE_URL, REDIS_URL, etc.) live in the root .env file.
#
# Setup:
#   cp apps/notification_service/.env.example apps/notification_service/.env
# =============================================================================


# ── Service Identity ──────────────────────────────────────────────────────────
# Logical name for this microservice — used in logs and health checks.
MICROSERVICE_NAME=NOTIFICATION_SERVICE


# ── Email Sending ─────────────────────────────────────────────────────────────
# The "From" address shown to recipients of transactional emails.
MAIL_FROM=noreply@fintrack.live

# API token used to authenticate with the email provider.
# For local development, use Mailtrap (free): https://mailtrap.io
#   Email API → API Tokens → copy the token for your inbox.
# For production, replace with a real SMTP provider token (SendGrid, Postmark, etc.).
MAIL_TOKEN=your-mailtrap-api-token

# Max DB connections for this service (Aiven free tier total: 16)
DB_POOL_MAX=1

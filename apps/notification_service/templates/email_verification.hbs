<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Verify your email - Fintrack</title>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f4f4f5;
        color: #3f3f46;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 440px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #e4e4e7;
      }

      .header {
        padding: 40px 40px 28px 40px;
        text-align: center;
        border-bottom: 1px solid #e4e4e7;
      }

      .logo {
        height: 48px;
        width: 48px;
        display: inline-block;
        border-radius: 10px;
        margin-bottom: 12px;
      }

      .brand-name {
        font-size: 16px;
        font-weight: 700;
        color: #18181b;
        letter-spacing: 0.1em;
        margin: 0;
        text-transform: uppercase;
      }

      .content {
        padding: 32px 40px 40px 40px;
        text-align: center;
      }

      .greeting {
        font-size: 16px;
        font-weight: 600;
        color: #18181b;
        margin: 0 0 12px 0;
      }

      .text {
        font-size: 14px;
        color: #71717a;
        margin: 0 0 24px 0;
        line-height: 1.6;
      }

      .otp-container {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        padding: 20px;
        margin: 24px 0;
      }

      .otp-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: #7c7aff;
        margin: 0 0 10px 0;
        font-weight: 700;
      }

      .otp-code {
        font-size: 32px;
        font-weight: 700;
        color: #18181b;
        letter-spacing: 0.2em;
        margin: 0;
        white-space: nowrap;
      }

      .footer {
        padding: 24px 40px;
        text-align: center;
        border-top: 1px solid #e4e4e7;
        background-color: #fafafa;
        font-size: 11px;
        color: #a1a1aa;
      }

      .footer a {
        color: #7c7aff;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <div class='header'>
          <img
            src='https://res.cloudinary.com/fintrack/image/upload/v1771540001/static/logo_qtfjng.jpg'
            alt='Fintrack'
            class='logo'
          />
          <h1 class='brand-name'>Fintrack</h1>
        </div>

        <div class='content'>
          <p class='greeting'>Hello {{firstName}},</p>
          <p class='text'>Welcome to the future of finance. Use the secure code
            below to verify your account.</p>

          <div class='otp-container'>
            <p class='otp-label'>Security Code</p>
            <div class='otp-code'>{{otp}}</div>
          </div>
        </div>

        <div class='footer'>
          <p>&copy; 2026 Fintrack Inc. &bull;
            <a href='https://fintrack.live'>fintrack.live</a></p>
        </div>
      </div>
    </div>
  </body>
</html>

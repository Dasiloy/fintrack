<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Payment Receipt - Fintrack</title>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f4f4f5;
        color: #3f3f46;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 440px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #e4e4e7;
      }

      .header {
        padding: 40px 40px 28px 40px;
        text-align: center;
        border-bottom: 1px solid #e4e4e7;
      }

      .logo {
        height: 48px;
        width: 48px;
        display: inline-block;
        border-radius: 10px;
        margin-bottom: 12px;
      }

      .brand-name {
        font-size: 16px;
        font-weight: 700;
        color: #18181b;
        letter-spacing: 0.1em;
        margin: 0;
        text-transform: uppercase;
      }

      .content {
        padding: 32px 40px 40px 40px;
      }

      .greeting {
        font-size: 16px;
        font-weight: 600;
        color: #18181b;
        margin: 0 0 12px 0;
      }

      .text {
        font-size: 14px;
        color: #71717a;
        margin: 0 0 24px 0;
        line-height: 1.6;
      }

      .amount-block {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        padding: 20px;
        margin: 0 0 16px 0;
        text-align: center;
      }

      .amount-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #a1a1aa;
        font-weight: 700;
        margin: 0 0 6px 0;
      }

      .amount-value {
        font-size: 28px;
        font-weight: 700;
        color: #18181b;
        margin: 0;
        letter-spacing: -0.02em;
      }

      .detail-box {
        background-color: #fafafa;
        border: 1px solid #e4e4e7;
        padding: 20px;
        margin: 0 0 24px 0;
      }

      .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 0;
        border-bottom: 1px solid #e4e4e7;
      }

      .detail-row:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .detail-row:first-child {
        padding-top: 0;
      }

      .detail-label {
        font-size: 12px;
        color: #a1a1aa;
        font-weight: 500;
      }

      .detail-value {
        font-size: 13px;
        color: #18181b;
        font-weight: 600;
        text-align: right;
      }

      .btn {
        display: block;
        background-color: #7c7aff;
        color: #ffffff !important;
        text-decoration: none;
        padding: 14px 32px;
        font-size: 14px;
        font-weight: 600;
        text-align: center;
        margin-bottom: 12px;
      }

      .btn-secondary {
        display: block;
        background-color: #ffffff;
        color: #3f3f46 !important;
        text-decoration: none;
        padding: 13px 32px;
        font-size: 14px;
        font-weight: 500;
        text-align: center;
        border: 1px solid #e4e4e7;
        margin-bottom: 12px;
      }

      .footer {
        padding: 24px 40px;
        text-align: center;
        border-top: 1px solid #e4e4e7;
        background-color: #fafafa;
        font-size: 11px;
        color: #a1a1aa;
        line-height: 1.7;
      }

      .footer a {
        color: #7c7aff;
        text-decoration: none;
        font-weight: 500;
      }
    </style>
  </head>
  <body>

    {{! firstName, currency, amountPaid, invoiceNumber, planName, periodStart, periodEnd, paymentDate, email, hostedInvoiceUrl, invoicePdfUrl, billingPortalUrl, supportEmail }}
    <div class='wrapper'>
      <div class='container'>
        <div class='header'>
          <img
            src='https://res.cloudinary.com/fintrack/image/upload/v1771540001/static/logo_qtfjng.jpg'
            alt='Fintrack'
            class='logo'
          />
          <h1 class='brand-name'>Fintrack</h1>
        </div>

        <div class='content'>
          <p class='greeting'>Payment received, {{firstName}}.</p>
          <p class='text'>Thanks for your continued subscription. Here's your
            receipt for this billing cycle.</p>

          <div class='amount-block'>
            <p class='amount-label'>Amount Paid</p>
            <p class='amount-value'>{{currency}} {{amountPaid}}</p>
          </div>

          <div class='detail-box'>
            <div class='detail-row'>
              <span class='detail-label'>Invoice</span>
              <span class='detail-value'>{{invoiceNumber}}</span>
            </div>
            <div class='detail-row'>
              <span class='detail-label'>Plan</span>
              <span class='detail-value'>{{planName}}</span>
            </div>
            <div class='detail-row'>
              <span class='detail-label'>Billing period</span>
              <span class='detail-value'>{{periodStart}} – {{periodEnd}}</span>
            </div>
            <div class='detail-row'>
              <span class='detail-label'>Payment date</span>
              <span class='detail-value'>{{paymentDate}}</span>
            </div>
            <div class='detail-row'>
              <span class='detail-label'>Billed to</span>
              <span class='detail-value'>{{email}}</span>
            </div>
          </div>

          <a href='{{hostedInvoiceUrl}}' class='btn'>View Invoice</a>
          <a href='{{invoicePdfUrl}}' class='btn-secondary'>Download PDF</a>
          <a href='{{billingPortalUrl}}' class='btn-secondary'>Manage Billing</a>
        </div>

        <div class='footer'>
          <p>Questions? Reach us at
            <a href='mailto:{{supportEmail}}'>{{supportEmail}}</a></p>
          <p>&copy; 2026 Fintrack Inc. &bull;
            <a href='https://fintrack.live'>fintrack.live</a></p>
        </div>
      </div>
    </div>
  </body>
</html>

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Password Changed - Fintrack</title>
    <style>
      body {
        font-family:
          'Manrope',
          'Inter',
          -apple-system,
          sans-serif;
        background-color: #0f0f14;
        color: #b4b4c0;
        margin: 0;
        padding: 0;
        line-height: 1.5;
      }
      .wrapper {
        background-color: #0f0f14;
        padding: 60px 20px;
      }
      .container {
        max-width: 440px;
        margin: 0 auto;
        background: linear-gradient(180deg, #1c1c23 0%, #18181d 100%);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        overflow: hidden;
        box-shadow: 0 40px 80px rgba(0, 0, 0, 0.4);
      }
      .header {
        padding: 40px 32px 24px 32px;
        text-align: center;
      }
      .logo {
        height: 48px;
        width: auto;
        margin-bottom: 12px;
      }
      .brand-name {
        font-size: 18px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: 0.2em;
        margin: 0;
        text-transform: uppercase;
      }
      .content {
        padding: 0px 40px 40px 40px;
        text-align: center;
      }
      .greeting {
        font-size: 20px;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 12px;
      }
      .text {
        font-size: 14px;
        color: #8b8b98;
        margin-bottom: 24px;
      }
      .status-badge {
        display: inline-block;
        background: rgba(124, 122, 255, 0.1);
        color: #7c7aff;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
        margin-bottom: 24px;
        border: 1px solid rgba(124, 122, 255, 0.2);
      }
      .footer {
        padding: 24px;
        text-align: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 11px;
        color: #5a5a68;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <div class='header'>
          <img
            src='https://res.cloudinary.com/fintrack/image/upload/v1771540001/static/logo_qtfjng.jpg'
            alt='Fintrack'
            class='logo'
          />
          <h1 class='brand-name'>Fintrack</h1>
        </div>

        <div class='content'>
          <p class='greeting'>Hello {{firstName}},</p>
          <div class='status-badge'>Security Update</div>
          <p class='text'>Your account password has been successfully changed.
            If you did not make this change, please contact our security team
            immediately.</p>
        </div>

        <div class='footer'>
          <p>&copy; 2026 Fintrack Inc. &bull; fintrack.live</p>
        </div>
      </div>
    </div>
  </body>
</html>

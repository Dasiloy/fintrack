<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Welcome to Fintrack!</title>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background-color: #f4f4f5;
        color: #3f3f46;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      .wrapper {
        background-color: #f4f4f5;
        padding: 40px 20px;
      }

      .container {
        max-width: 520px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #e4e4e7;
      }

      .header {
        padding: 40px 40px 28px 40px;
        text-align: center;
        border-bottom: 1px solid #e4e4e7;
      }

      .logo {
        height: 48px;
        width: 48px;
        display: inline-block;
        border-radius: 10px;
        margin-bottom: 20px;
      }

      .hero-title {
        font-size: 24px;
        font-weight: 700;
        color: #18181b;
        letter-spacing: -0.02em;
        margin: 0 0 10px 0;
        line-height: 1.3;
      }

      .hero-subtitle {
        font-size: 15px;
        color: #71717a;
        margin: 0;
      }

      .content {
        padding: 32px 40px 40px 40px;
      }

      .greeting {
        font-size: 16px;
        font-weight: 600;
        color: #18181b;
        margin: 0 0 20px 0;
      }

      .features-grid {
        margin: 24px 0;
      }

      .feature-card {
        padding: 20px;
        margin-bottom: 12px;
        border: 1px solid #e4e4e7;
        background-color: #fafafa;
      }

      .feature-icon {
        font-size: 20px;
        margin-bottom: 10px;
        display: inline-block;
      }

      .feature-name {
        font-size: 15px;
        font-weight: 600;
        color: #18181b;
        margin-bottom: 6px;
        display: block;
      }

      .feature-desc {
        font-size: 13px;
        color: #71717a;
        margin: 0;
        line-height: 1.5;
      }

      .ai-tag {
        display: inline-block;
        padding: 2px 8px;
        background-color: #ede9fe;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 700;
        color: #6d28d9;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        vertical-align: middle;
        margin-left: 8px;
      }

      .cta-container {
        text-align: center;
        margin-top: 32px;
      }

      .btn {
        display: inline-block;
        background-color: #7c7aff;
        color: #ffffff !important;
        text-decoration: none;
        padding: 14px 32px;
        font-size: 15px;
        font-weight: 600;
      }

      .footer {
        padding: 28px 40px;
        text-align: center;
        border-top: 1px solid #e4e4e7;
        background-color: #fafafa;
      }

      .footer-text {
        font-size: 13px;
        color: #71717a;
        margin: 0 0 12px 0;
      }

      .social-links {
        margin-bottom: 16px;
      }

      .social-links a {
        color: #7c7aff;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        margin: 0 10px;
      }

      .legal {
        font-size: 11px;
        color: #a1a1aa;
        margin: 0;
        line-height: 1.7;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <div class='header'>
          <img
            src='https://res.cloudinary.com/fintrack/image/upload/v1771540001/static/logo_qtfjng.jpg'
            alt='Fintrack'
            class='logo'
          />
          <h1 class='hero-title'>Your Financial Hero Awaits.</h1>
          <p class='hero-subtitle'>You're officially verified and ready to
            master your money with Fintrack.</p>
        </div>

        <div class='content'>
          <p class='greeting'>Verified! Welcome {{firstName}}.</p>

          <div class='features-grid'>
            <div class='feature-card'>
              <div class='feature-icon'>✨</div>
              <span class='feature-name'>AI Smart Categorization
                <span class='ai-tag'>AI Powered</span></span>
              <p class='feature-desc'>Stop manual sorting. Our neural engine
                automatically organizes every cent into intuitive categories
                with 99% accuracy.</p>
            </div>

            <div class='feature-card' style='border-left: 3px solid #00D9A5;'>
              <div class='feature-icon'>🤖</div>
              <span class='feature-name'>Smart Financial Decisions
                <span
                  class='ai-tag'
                  style='background-color: #d1fae5; color: #065f46;'
                >New</span>
              </span>
              <p class='feature-desc'>Get personalized, AI-driven advice on how
                to optimize your subscriptions, save on fees, and reach your
                goals faster.</p>
            </div>

            <div class='feature-card'>
              <div class='feature-icon'>📊</div>
              <span class='feature-name'>Deep Glossy Analytics</span>
              <p class='feature-desc'>Visualize your wealth like never before
                with beautiful, interactive charts that bring your data to life.</p>
            </div>
          </div>

          <p
            style='font-size: 14px; color: #71717a; margin-top: 28px; margin-bottom: 0; text-align: center;'
          >
            See you on the inside!<br />
            <strong style='color: #18181b;'>The Fintrack Team</strong>
          </p>
        </div>

        <div class='footer'>
          <p class='footer-text'>The only financial tool you'll ever need.</p>
          <div class='social-links'>
            <a href='https://www.fintrack.live/support'>Support</a>
            <a href='https://www.fintrack.live/community'>Community</a>
          </div>
          <p class='legal'>
            &copy; 2026 Fintrack Inc. All rights reserved.<br />
            Designed for modern financial freedom.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>

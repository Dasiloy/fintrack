<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Confirm your new email - Fintrack</title>
    <style>
      body {
        font-family:
          'Manrope',
          'Inter',
          -apple-system,
          sans-serif;
        background-color: #0f0f14;
        color: #b4b4c0;
        margin: 0;
        padding: 0;
        line-height: 1.5;
      }
      .wrapper {
        background-color: #0f0f14;
        padding: 60px 20px;
      }
      .container {
        max-width: 440px;
        margin: 0 auto;
        background: linear-gradient(180deg, #1c1c23 0%, #18181d 100%);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        overflow: hidden;
        box-shadow: 0 40px 80px rgba(0, 0, 0, 0.4);
      }
      .header {
        padding: 40px 32px 24px 32px;
        text-align: center;
      }
      .logo {
        height: 48px;
        width: auto;
        margin-bottom: 12px;
      }
      .brand-name {
        font-size: 18px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: 0.2em;
        margin: 0;
        text-transform: uppercase;
      }
      .content {
        padding: 0px 40px 40px 40px;
        text-align: center;
      }
      .greeting {
        font-size: 20px;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 12px;
      }
      .text {
        font-size: 14px;
        color: #8b8b98;
        margin-bottom: 24px;
      }
      .otp-container {
        background: rgba(124, 122, 255, 0.05);
        border: 1px dashed rgba(124, 122, 255, 0.2);
        border-radius: 12px;
        padding: 16px 20px;
        margin: 24px 0;
      }
      .otp-label {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: #7c7aff;
        margin-bottom: 8px;
        font-weight: 800;
      }
      .otp-code {
        font-size: 28px;
        font-weight: 800;
        color: #ffffff;
        letter-spacing: 0.15em;
        margin: 0;
        white-space: nowrap;
        text-shadow: 0 0 20px rgba(124, 122, 255, 0.3);
      }
      .warning {
        font-size: 12px;
        color: #5a5a68;
        margin-top: 16px;
      }
      .footer {
        padding: 24px;
        text-align: center;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 11px;
        color: #5a5a68;
      }
      .footer a {
        color: #7c7aff;
        text-decoration: none;
        font-weight: 600;
      }
      .footer a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <div class='wrapper'>
      <div class='container'>
        <div class='header'>
          <img
            src='https://res.cloudinary.com/fintrack/image/upload/v1771540001/static/logo_qtfjng.jpg'
            alt='Fintrack'
            class='logo'
          />
          <h1 class='brand-name'>Fintrack</h1>
        </div>

        <div class='content'>
          <p class='greeting'>Hello {{firstName}},</p>
          <p class='text'>You requested to change your Fintrack email address.
            Use the code below to confirm this is your new address. This code
            expires in 5 minutes.</p>

          <div class='otp-container'>
            <p class='otp-label'>Confirmation Code</p>
            <div class='otp-code'>{{otp}}</div>
          </div>

          <p class='warning'>If you did not request an email change, your account
            may be compromised. Please contact our security team immediately.</p>
        </div>

        <div class='footer'>
          <p>&copy; 2026 Fintrack Inc. &bull; <a href='https://fintrack.live'>fintrack.live</a></p>
        </div>
      </div>
    </div>
  </body>
</html>

# =============================================================================
# API Gateway — Local Environment Variables Template
#
# These vars are specific to the api_gateway service.
# The majority of shared vars (JWT, DB, service hosts, etc.) live in the
# root .env file, which is loaded first via dotenv-expand.
#
# Setup:
#   cp apps/api_gateway/.env.example apps/api_gateway/.env
# =============================================================================


# ── Service Identity ──────────────────────────────────────────────────────────
# Logical name for this microservice — used in logs and health checks.
MICROSERVICE_NAME=API_GATEWAY


# ── Swagger UI Basic Auth ─────────────────────────────────────────────────────
# The Swagger docs (/api/docs) are protected by HTTP basic auth in non-dev
# environments. Choose any username and password for local development.
# IMPORTANT: change these before deploying to production.
SWAGGER_DOC_USER=fintrack
SWAGGER_DOC_PASS=developer



# Max DB connections for this service (Aiven free tier total: 16)
DB_POOL_MAX=3

# =============================================================================
# Payment Service — Local Environment Variables Template
#
# These vars are specific to the payment_service gRPC microservice.
# Shared vars (DATABASE_URL, REDIS_URL, etc.) live in the root .env file.
#
# Setup:
#   cp apps/payment_service/.env.example apps/payment_service/.env

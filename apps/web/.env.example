# =============================================================================
# Web App (Next.js) — Local Environment Variables Template
#
# These vars are specific to the Next.js web application.
# Shared vars (AUTH_SECRET, AUTH_GOOGLE_ID/SECRET, API_GATEWAY_URL, etc.)
# live in the root .env file and are automatically available here.
#
# Setup:
#   cp apps/web/.env.example apps/web/.env
# =============================================================================


# ── NextAuth ──────────────────────────────────────────────────────────────────
# Base URL NextAuth uses to build callback/redirect URLs.
# Must exactly match the URL you access the app from in the browser.
NEXTAUTH_URL=http://localhost:3000


# ── Public App URL ────────────────────────────────────────────────────────────
# Used by client-side code to build absolute URLs (e.g. share links).
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Google Analytics ──────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID.
# Google Analytics: https://analytics.google.com
#   Admin → Data Streams → Web → Measurement ID (format: G-XXXXXXXXXX)
# Leave as G-XXXXXXXXXX to disable analytics in development.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# ── Device Fingerprinting Cookie ─────────────────────────────────────────────
# Name of the cookie used to store the device fingerprint / device ID.
NEXT_PUBLIC_DEVICE_ID_COOKIE_NAME=x-device-id

# Max age of the device ID cookie in seconds (31536000 = 1 year).
DEVICE_ID_COOKIE_MAX_AGE=31536000

model Currencies {
  id       String   @id @default(cuid())
  currency Currency
  label    String

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Language {
  // Core “base” languages
  EN // en
  FR // fr
  ES // es
  PT // pt

  // Key English variants
  EN_US // en-US
  EN_GB // en-GB

  // Important regional languages for NG/Africa
  HA_LATN_NG // ha-Latn-NG
  YO_NG // yo-NG
  IG_NG // ig-NG
  SW_KE // sw-KE
  SW_TZ // sw-TZ
}

model Locale {
  id       String   @id @default(cuid())
  language Language
  label    String

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DateFormat {
  DMY
  MDY
  YMD
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String?
  loginAttempts   Int       @default(0)
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  firstName       String
  lastName        String
  avatar          String?
  lastLoginAt     DateTime?

  // 2FA fileds
  twoFactorAttempts   Int       @default(0)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String? // base32 TOTP secret, null until setup initiated => Encrypted
  twoFactorLastUsedAt DateTime?

  // preferences
  currency   Currency   @default(NGN)
  language   Language   @default(EN_US)
  timezone   String     @default("Africa/Lagos")
  dateFormat DateFormat @default(DMY)

  // reverse relationship
  accounts         Account[]
  sessions         Session[]
  subscription     Subscription?
  usageTrackers    UsageTracker[]
  backupCodes      BackupCodes[]
  loginActivity    LoginActivity[]
  setting          NotificationSetting?
  categories       Category[]
  transactions     Transaction[]
  budgets          Budget[]
  recurringItems   RecurringItem[]
  goals            Goal[]
  splits           Split[]
  ocrDrafts        OCRDraft[]
  fcmDevices       FcmDevice[]
  activityLogs     ActivityLogs[]
  monoBankAccounts MonoBankAccount[]
  notifications    Notification[]

  // account deletion
  scheduledDeletionAt DateTime?

  // time stamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AccountType {
  OAUTH
  OIDC
  CREDENTIALS
}

enum AccountProvider {
  GOOGLE
  GITHUB
  APPLE
  LOCAL
}

model Account {
  id                String          @id @default(cuid())
  userId            String
  type              AccountType
  provider          AccountProvider
  providerAccountId String
  refreshToken      String?         @db.Text
  accessToken       String?         @db.Text
  expiresAt         Int?
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // time stamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  deviceId     String
  userAgent    String?
  ipAddress    String?
  location     String?
  lastUsedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // time stamps
  createdAt DateTime @default(now())

  @@unique([userId, deviceId])
}

enum LoginActivityType {
  PASSWORD
  MFA
}

enum LoginActivityStatus {
  FALED
  SUCCESS
}

model LoginActivity {
  id        String              @id @default(cuid())
  type      LoginActivityType
  status    LoginActivityStatus
  deviceId  String
  userAgent String?
  ipAddress String?
  location  String?

  // foreign relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // time stamps
  createdAt DateTime @default(now())
}

enum VerificationIdentifier {
  PASSWORD
  EMAIL
  RESET
  EMAIL_CHANGE
}

model VerificationToken {
  id         String                 @id @default(cuid())
  identifier VerificationIdentifier
  email      String
  token      String
  newEmail   String? // pending target email, used only for EMAIL_CHANGE flows
  expires    DateTime

  // time stamps
  createdAt DateTime @default(now())

  @@unique([email, token, identifier])
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

model Subscription {
  id                       String             @id @default(cuid())
  userId                   String             @unique
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId         String?            @unique
  stripeSubscriptionId     String?            @unique
  stripePriceId            String?
  stripeCurrentPeriodStart DateTime?
  stripeCurrentPeriodEnd   DateTime?
  stripeCancelAtPeriodEnd  Boolean            @default(false)
  status                   SubscriptionStatus @default(ACTIVE)
  plan                     SubscriptionPlan   @default(FREE)

  // timstamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StripeWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique // Stripe event.id
  eventType   String
  processedAt DateTime @default(now())
}

enum UsageFeature {
  AI_INSIGHTS_QUERIES
  AI_CHAT_MESSAGES
  RECEIPT_UPLOADS
}

model UsageTracker {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature     UsageFeature
  count       Int          @default(0)
  periodStart DateTime // First day of current month (UTC midnight)
  periodEnd   DateTime // First day of next month (UTC midnight)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, feature, periodStart])
  @@index([userId, feature])
}

model BackupCodes {
  id     String    @id @default(cuid())
  usedAt DateTime?
  code   String // Hashed Code For Security, Contains the secret andiv as secret:iv
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ActivityLogs {
  id         String @id @default(cuid())
  event      String // transaction.created, budget.created, goal.created, split.created, etc.
  entityId   String
  entityType String // transaction, budget, goal, split, etc.
  data       Json //{source: "manual", sourceId: "123", old: {amount: 100, date: "2021-01-01"}, new: {amount: 200, date: "2021-01-01"}} depnds on the event, transaction data are encoded in the data field

  // relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
}

model NotificationSetting {
  id String @id @default(cuid())

  // budget alerts
  budgetAlertMail Boolean @default(true)
  budgetAlertApp  Boolean @default(true)

  // reminders
  billReminderMail Boolean @default(true)
  billReminderApp  Boolean @default(true)

  // weekly reports
  weeklyReportMail Boolean @default(true)
  weeklyReportApp  Boolean @default(true)

  // ai insights
  aiInsightsMail Boolean @default(true)
  aiInsightsApp  Boolean @default(true)

  // goals
  goalsAlertMail Boolean @default(true)
  goalsAlertApp  Boolean @default(true)

  // splits
  splitsAlertMail Boolean @default(true)
  splitsAlertApp  Boolean @default(true)

  //news letter
  newsLetterAlert Boolean @default(false)

  // community updates
  communityAlert Boolean @default(false)

  // relations
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String?
  color       String?
  isSystem    Boolean @default(false) // true = generic, false = user-created

  // nullable relation — null means it's a system/generic category
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  transactions   Transaction[]
  budgets        Budget[]
  recurringItems RecurringItem[]

  @@unique([name, userId]) // prevents duplicate names per user, but allows
  // same name across different users or system
  @@index([userId])
  @@index([isSystem])
}

enum BudgetPeriod {
  MONTHLY
  WEEKLY
  QUARTERLY
  YEARLY
}

model Budget {
  id             String       @id @default(cuid())
  name           String
  amount         Float
  description    String?
  period         BudgetPeriod @default(MONTHLY)
  carryOver      Boolean      @default(false) // will always be false for V1
  alertThreshold Float        @default(0.8) // 80% of budget

  // classification
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // relationships
  budgetHistory BudgetHistory[]

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, categoryId, period])
}

// SCD => Slowly Changing Dimension Tracking Limit changes over time
model BudgetHistory {
  id        String    @id @default(cuid())
  limit     Float
  startDate DateTime
  endDate   DateTime?

  // relationships
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([budgetId, startDate])
}

enum OCRDraftStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model OCRDraft {
  id            String         @id @default(cuid())
  amount        Float?
  date          DateTime
  description   String?
  notes         String?
  merchant      String?
  imageKey      String         @unique
  status        OCRDraftStatus @default(PENDING)
  confidence    Float?
  faliureReason String?
  rawData       Json?
  confirmedAt   DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([imageKey])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  MANUAL
  BANK
  RECURRING
  OCR
  SPLIT
}

enum BankTransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

model Transaction {
  id          String          @id @default(cuid())
  amount      Float
  date        DateTime
  type        TransactionType
  description String?
  notes       String?
  merchant    String?

  // classification
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // ownership
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // source metadata
  source     TransactionSource @default(MANUAL)
  sourceId   String // OCR Jobid, Mono TransactionID
  sourceData Json? // JSON blob for OCR/Split/mono/etc. metadata

  // mono bank data
  bankTransactionId     String?
  bankTransactionStatus BankTransactionStatus @default(COMPLETED) // Only Completed transactions are supported in V1

  // relations
  split            Split?
  goalContribution GoalContribution?
  settlements      SplitSettlement[]
  // goals contribution

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  monoBankAccountId String?          @unique // ensure idempotency
  monoBankAccount   MonoBankAccount? @relation(fields: [monoBankAccountId], references: [id])

  @@unique([userId, source, sourceId])
  @@unique([userId, bankTransactionId, monoBankAccountId])
  @@index([userId, date])
  @@index([userId, source])
  @@index([userId, categoryId])
  @@index([monoBankAccountId, bankTransactionId]) // ensure idempotency
}

enum RecurringItemFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

model RecurringItem {
  id          String                 @id @default(cuid())
  name        String
  amount      Float
  type        TransactionType
  frequency   RecurringItemFrequency
  startDate   DateTime
  endDate     DateTime?
  description String?
  notes       String?
  merchant    String?

  // trackers
  lastRunAt DateTime? // null if never run
  nextRunAt DateTime
  isActive  Boolean   @default(true)

  // classification
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Goalstatus {
  ACTIVE
  COMPLETED
}

enum GoalPriority {
  LOW
  MEDIUM
  HIGH
}

model Goal {
  id           String     @id @default(cuid())
  name         String
  targetAmount Float
  targetDate   DateTime
  status       Goalstatus @default(ACTIVE)
  description  String?

  priority    GoalPriority  @default(MEDIUM)

  // owner
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // relationships
  contributions GoalContribution[]

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id,userId])
}

model GoalContribution {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime
  description String?
  notes       String?

  // relationship
  goalId        String
  goal          Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade) // goal contribution transaction can only be expense transaction

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id,goalId])
}

enum SplitStatus {
  OPEN
  PARTIALLY_SETTLED
  SETTLED
}

model Split {
  id     String      @id @default(cuid())
  name   String
  amount Float
  status SplitStatus @default(OPEN)

  // ownership
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Restrict)

  // relationships
  participants SplitParticipant[]
  settlements  SplitSettlement[]

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SplitParticipant {
  id     String @id @default(cuid())
  name   String
  email  String
  amount Float

  // relationships
  splitId String
  split   Split  @relation(fields: [splitId], references: [id], onDelete: Cascade)

  settlements SplitSettlement[]

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SplitSettlement {
  id         String   @id @default(cuid())
  paidAt     DateTime
  paidAmount Float

  // relationships
  splitId       String
  split         Split            @relation(fields: [splitId], references: [id], onDelete: Cascade)
  participantId String
  participant   SplitParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  transactionId String?           @unique
  transaction   Transaction?      @relation(fields: [transactionId], references: [id], onDelete: Cascade) // split settlement transaction can only be income transaction

  // timestamp
  createdAt DateTime @default(now())
}

model MonoBankAccount {
  id              String    @id @default(cuid())
  accountId       String    @unique
  bankId          String
  bankLogoUrl     String?
  accountNumber   String
  accountName     String
  accountType     String
  accountBalance  Float
  accountCurrency Currency
  isActive        Boolean   @default(true)
  lastSyncedAt    DateTime?

  // ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // relationships
  transactions Transaction[]

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, accountId])
}

model FcmDevice {
  id       String @id @default(cuid())
  fcmToken String

  //relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, fcmToken])
}

model Notification {
  id             String    @id @default(cuid())
  title          String
  body           String
  data           Json?
  readAt         DateTime?
  read           Boolean   @default(false)
  archivedAt     DateTime?
  archived       Boolean   @default(false)
  notificationId String    @unique

  // ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

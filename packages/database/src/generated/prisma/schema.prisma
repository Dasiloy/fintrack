model Currencies {
  id       String   @id @default(cuid())
  currency Currency
  label    String

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Language {
  // Core “base” languages
  EN // en
  FR // fr
  ES // es
  PT // pt

  // Key English variants
  EN_US // en-US
  EN_GB // en-GB

  // Important regional languages for NG/Africa
  HA_LATN_NG // ha-Latn-NG
  YO_NG // yo-NG
  IG_NG // ig-NG
  SW_KE // sw-KE
  SW_TZ // sw-TZ
}

model Locale {
  id       String   @id @default(cuid())
  language Language
  label    String

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DateFormat {
  DMY
  MDY
  YMD
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String?
  loginAttempts   Int       @default(0)
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  firstName       String
  lastName        String
  avatar          String?
  lastLoginAt     DateTime?

  // 2FA fileds
  twoFactorAttempts   Int       @default(0)
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String? // base32 TOTP secret, null until setup initiated => Encrypted
  twoFactorLastUsedAt DateTime?

  // preferences
  currency   Currency   @default(NGN)
  language   Language   @default(EN_US)
  timezone   String     @default("Africa/Lagos")
  dateFormat DateFormat @default(DMY)

  // reverse relationship
  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  usageTrackers UsageTracker[]
  backupCodes   BackupCodes[]
  loginActivity LoginActivity[]
  setting       NotificationSetting?

  // account deletion
  scheduledDeletionAt DateTime?

  // time stamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AccountType {
  OAUTH
  OIDC
  CREDENTIALS
}

enum AccountProvider {
  GOOGLE
  GITHUB
  APPLE
  LOCAL
}

model Account {
  id                String          @id @default(cuid())
  userId            String
  type              AccountType
  provider          AccountProvider
  providerAccountId String
  refreshToken      String?         @db.Text
  accessToken       String?         @db.Text
  expiresAt         Int?
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  // time stamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  deviceId     String
  userAgent    String?
  ipAddress    String?
  location     String?
  lastUsedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // time stamps
  createdAt DateTime @default(now())

  @@unique([userId, deviceId])
}

enum LoginActivityType {
  PASSWORD
  MFA
}

enum LoginActivityStatus {
  FALED
  SUCCESS
}

model LoginActivity {
  id        String              @id @default(cuid())
  type      LoginActivityType
  status    LoginActivityStatus
  deviceId  String
  userAgent String?
  ipAddress String?
  location  String?

  // foreign relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // time stamps
  createdAt DateTime @default(now())
}

enum VerificationIdentifier {
  PASSWORD
  EMAIL
  RESET
  EMAIL_CHANGE
}

model VerificationToken {
  id         String                 @id @default(cuid())
  identifier VerificationIdentifier
  email      String
  token      String
  newEmail   String? // pending target email, used only for EMAIL_CHANGE flows
  expires    DateTime

  // time stamps
  createdAt DateTime @default(now())

  @@unique([email, token, identifier])
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

model Subscription {
  id                       String             @id @default(cuid())
  userId                   String             @unique
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId         String?            @unique
  stripeSubscriptionId     String?            @unique
  stripePriceId            String?
  stripeCurrentPeriodStart DateTime?
  stripeCurrentPeriodEnd   DateTime?
  stripeCancelAtPeriodEnd  Boolean            @default(false)
  status                   SubscriptionStatus @default(ACTIVE)
  plan                     SubscriptionPlan   @default(FREE)

  // timstamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StripeWebhookEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique // Stripe event.id
  eventType   String
  processedAt DateTime @default(now())
}

enum UsageFeature {
  AI_INSIGHTS_QUERIES
  AI_CHAT_MESSAGES
  RECEIPT_UPLOADS
}

model UsageTracker {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature     UsageFeature
  count       Int          @default(0)
  periodStart DateTime // First day of current month (UTC midnight)
  periodEnd   DateTime // First day of next month (UTC midnight)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([userId, feature, periodStart])
  @@index([userId, feature])
}

model BackupCodes {
  id     String    @id @default(cuid())
  usedAt DateTime?
  code   String // Hashed Code For Security, Contains the secret andiv as secret:iv
  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ActivityLogs {
  id String @id @default(cuid())
  // track transactyions and crud operations
  // track budget and crud operations
  // track biiklings and subscriptions an crud and crons
  // track gaols and splist
}

model NotificationSetting {
  id String @id @default(cuid())

  // budget alerts
  budgetAlertMail Boolean @default(true)
  budgetAlertApp  Boolean @default(true)

  // reminders
  billReminderMail Boolean @default(true)
  billReminderApp  Boolean @default(true)

  // weekly reports
  weeklyReportMail Boolean @default(true)
  weeklyReportApp  Boolean @default(true)

  // ai insights
  aiInsightsMail Boolean @default(true)
  aiInsightsApp  Boolean @default(true)

  // goals
  goalsAlertMail Boolean @default(true)
  goalsAlertApp  Boolean @default(true)

  // splits
  splitsAlertMail Boolean @default(true)
  splitsAlertApp  Boolean @default(true)

  //news letter
  newsLetterAlert Boolean @default(false)

  // community updates
  communityAlert Boolean @default(false)

  // relations
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // timestamp
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

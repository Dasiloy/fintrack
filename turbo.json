{
  "ui": "stream",
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "SKIP_ENV_VALIDATION",
    "PORT",
    "VERCEL_URL",

    "DATABASE_URL",
    "DATABASE_CA_CERTIFICATE",
    "REDIS_URL",

    "AUTH_SECRET",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",

    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "JWT_OTP_SECRET",
    "JWT_ACCESS_TOKEN_EXPIRATION",
    "JWT_REFRESH_TOKEN_EXPIRATION",
    "JWT_OTP_TOKEN_EXPIRATION",
    "MAX_LOGIN_ATTEMPTS",
    "OTP_EXPIRY_MINUTES",

    "MAIL_FROM",
    "MAIL_TOKEN",

    "API_GATEWAY_URL",
    "API_GATEWAY_HOST",
    "API_GATEWAY_PORT",
    "AUTH_SERVICE_HOST",
    "AUTH_SERVICE_PORT",
    "AI_SERVICE_HOST",
    "AI_SERVICE_PORT",
    "FINANCE_SERVICE_HOST",
    "FINANCE_SERVICE_PORT",
    "SCHEDULER_SERVICE_HOST",
    "SCHEDULER_SERVICE_PORT",
    "PAYMENT_SERVICE_HOST",
    "PAYMENT_SERVICE_PORT",
    "SCHEDULER_SERVICE_HOST",
    "SCHEDULER_SERVICE_PORT",
    "NOTIFICATION_SERVICE_HOST",
    "NOTIFICATION_SERVICE_PORT",

    "CLOUDINARY_URL",
    "CLOUDINARY_SIGNATURE_EXPIRATION",

    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PUBLISHABLE_KEY",
    "STRIPE_PRO_MONTHLY_PRICE_ID",

    "SWAGGER_DOC_USER",
    "SWAGGER_DOC_PASS"
  ],
  "globalPassThroughEnv": [
    "AWS_SECRET_KEY",
    "GITHUB_TOKEN",
    "OPENAI_API_KEY",
    "OPENAI_API_BASE",
    "OPENAI_API_MODEL",
    "OPENAI_API_VERSION"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^db:generate", "^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "env": ["NEXT_PUBLIC_*"],
      "envMode": "strict",
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "proto:gen": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:deploy": {
      "cache": false
    }
  }
}

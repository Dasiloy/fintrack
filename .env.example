# =============================================================================
# FinTrack — Environment Variables Template
#
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# NEVER commit .env — it is listed in .gitignore.
# Add production values as GitHub Actions secrets (see docs/DOCKER.md).
# =============================================================================

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ── Redis (Upstash or self-hosted) ────────────────────────────────────────────
# Use rediss:// (TLS) for Upstash, redis:// for local
REDIS_URL=rediss://default:token@host:6379

# ── JWT secrets ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-long-random-string
JWT_REFRESH_SECRET=change-me-another-long-random-string
JWT_OTP_SECRET=change-me-otp-secret

JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=1d
JWT_OTP_TOKEN_EXPIRATION=60m

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Must match JWT_SECRET — used for session signing
AUTH_SECRET=${JWT_SECRET}

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → Credentials → OAuth 2.0
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Rate limiting ─────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=3
OTP_EXPIRY_MINUTES=5

# ── API Gateway ───────────────────────────────────────────────────────────────
API_GATEWAY_HOST=127.0.0.1
API_GATEWAY_PORT=4001
# Public URL used by the Next.js app to call the API
API_GATEWAY_URL=http://localhost:4001

# Swagger UI basic-auth (change before deploying!)
SWAGGER_DOC_USER=fintrack
SWAGGER_DOC_PASS=developer

# ── Microservices (gRPC) ──────────────────────────────────────────────────────
# Local development: 127.0.0.1
# Docker Compose: use the service name (e.g. auth_service)
AUTH_SERVICE_HOST=127.0.0.1
AUTH_SERVICE_PORT=4002

PAYMENT_SERVICE_HOST=127.0.0.1
PAYMENT_SERVICE_PORT=4008

NOTIFICATION_SERVICE_HOST=127.0.0.1
NOTIFICATION_SERVICE_PORT=4009

# ── Email (Mailtrap) ──────────────────────────────────────────────────────────
MAIL_FROM=noreply@fintrack.live
MAIL_TOKEN=your-mailtrap-api-token

# ── Next.js public vars ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Microservice identity (set per-container, not in shared .env) ─────────────
# MICROSERVICE_NAME=AUTH_SERVICE   # set in docker-compose per service

# ── GitHub Actions secrets reference ─────────────────────────────────────────
# Add these in: GitHub repo → Settings → Secrets and variables → Actions
#
#   DOCKERHUB_USERNAME          dasiloy
#   DOCKERHUB_TOKEN             Docker Hub access token (not your password)
#                               Create at: hub.docker.com → Account Settings → Security
#
#   DATABASE_URL                Production database connection string
#   REDIS_URL                   Production Redis URL
#   JWT_SECRET                  Production JWT secret
#   JWT_REFRESH_SECRET          Production refresh secret
#   JWT_OTP_SECRET              Production OTP secret
#   AUTH_SECRET                 Must equal JWT_SECRET
#   AUTH_GOOGLE_ID              Google OAuth client ID
#   AUTH_GOOGLE_SECRET          Google OAuth client secret
#   MAIL_FROM                   Sender email address
#   MAIL_TOKEN                  Mailtrap API token
#   SWAGGER_DOC_USER            Swagger basic-auth username
#   SWAGGER_DOC_PASS            Swagger basic-auth password
#   MAX_LOGIN_ATTEMPTS          (optional, default 3)
#   OTP_EXPIRY_MINUTES          (optional, default 5)
#   JWT_ACCESS_TOKEN_EXPIRATION (optional, default 15m)
#   JWT_REFRESH_TOKEN_EXPIRATION (optional, default 1d)
#   JWT_OTP_TOKEN_EXPIRATION    (optional, default 60m)
#
#   RENDER_DEPLOY_HOOK_API_GATEWAY          Render deploy hook URL
#   RENDER_DEPLOY_HOOK_AUTH_SERVICE         Render deploy hook URL
#   RENDER_DEPLOY_HOOK_NOTIFICATION_SERVICE Render deploy hook URL
#   RENDER_DEPLOY_HOOK_PAYMENT_SERVICE      Render deploy hook URL

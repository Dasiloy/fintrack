# =============================================================================
# FinTrack — Root Environment Variables Template
#
# This file is shared by all apps/services running in the monorepo.
# Each app may also have its own .env.example for service-specific vars.
#
# Setup:
#   cp .env.example .env
#   # Then fill in real values — see comments below for where to get each one.
#
# NEVER commit .env — it is listed in .gitignore.
# Add production values as GitHub Actions secrets (see docs/DOCKER.md).
# =============================================================================


# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL (free tier): https://neon.tech
#   Create a project → Connection Details → copy the "Pooled connection" string.
#   Format: postgresql://<user>:<password>@<host>/<db>?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DATABASE_CA_CERTIFICATE=your-database-ca-certificate-in-base64

# ── Redis ─────────────────────────────────────────────────────────────────────
# Upstash Redis (free tier): https://upstash.com
#   Create a Redis database → Details tab → copy REDIS_URL.
#   Must use rediss:// (TLS) for Upstash. Use redis:// only for local Redis.
REDIS_URL=rediss://default:your-upstash-token@your-host.upstash.io:6379


# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 48
# Use a different random value for every secret.
JWT_SECRET=your-jwt-secret-generate-with-openssl-rand-base64-48
JWT_REFRESH_SECRET=your-jwt-refresh-secret-generate-with-openssl-rand-base64-48
JWT_OTP_SECRET=your-jwt-otp-secret-generate-with-openssl-rand-base64-48

# Token expiration durations (ms/zeit format — e.g. 15m, 1h, 7d)
JWT_ACCESS_TOKEN_EXPIRATION=1h
JWT_REFRESH_TOKEN_EXPIRATION=1d
JWT_OTP_TOKEN_EXPIRATION=60m


# ── OTP / Login Rate-Limiting ─────────────────────────────────────────────────
# How long (minutes) an OTP code is valid before it expires
OTP_EXPIRY_MINUTES=5
# How many failed login attempts are allowed before the account is locked
MAX_LOGIN_ATTEMPTS=3


# ── NextAuth ──────────────────────────────────────────────────────────────────
# Must equal JWT_SECRET — used by NextAuth.js to sign session tokens.
# You can use the literal variable reference shown below, or copy the value.
AUTH_SECRET=${JWT_SECRET}


# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console: https://console.cloud.google.com
#   APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
#   Application type: Web application
#   Authorised redirect URIs: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret


# ── Cloudinary ────────────────────────────────────────────────────────────────
# Cloudinary (free tier): https://cloudinary.com
#   Dashboard → Cloud name (this is your CLOUDINARY_ID)
CLOUDINARY_ID=your-cloudinary-cloud-name


# ── Web App URLs ──────────────────────────────────────────────────────────────
# Public base URL of the Next.js web app (used for redirects, CORS, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── API Gateway ───────────────────────────────────────────────────────────────
# Host and port the API Gateway NestJS server listens on
API_GATEWAY_HOST=127.0.0.1
API_GATEWAY_PORT=4001
# Full URL used by Next.js (and mobile) to reach the API Gateway
API_GATEWAY_URL=http://localhost:4001


# ── Microservice Hosts & Ports (gRPC) ────────────────────────────────────────
# For local development keep 127.0.0.1.
# For Docker Compose, replace with the container service name (e.g. auth_service).
AUTH_SERVICE_HOST=127.0.0.1
AUTH_SERVICE_PORT=4002

PAYMENT_SERVICE_HOST=127.0.0.1
PAYMENT_SERVICE_PORT=4008

NOTIFICATION_SERVICE_HOST=127.0.0.1
NOTIFICATION_SERVICE_PORT=4009


# ── GitHub Actions Secrets Reference ─────────────────────────────────────────
# The following variables must also be added to:
#   GitHub repo → Settings → Secrets and variables → Actions
#
#   DOCKERHUB_USERNAME                  Your Docker Hub username (e.g. dasiloy)
#   DOCKERHUB_TOKEN                     Docker Hub access token (not your password)
#                                       hub.docker.com → Account Settings → Security
#
#   DATABASE_URL                        Production Neon connection string
#   REDIS_URL                           Production Upstash Redis URL
#   JWT_SECRET                          Production JWT secret
#   JWT_REFRESH_SECRET                  Production refresh secret
#   JWT_OTP_SECRET                      Production OTP secret
#   AUTH_SECRET                         Must equal JWT_SECRET
#   AUTH_GOOGLE_ID                      Google OAuth client ID
#   AUTH_GOOGLE_SECRET                  Google OAuth client secret
#   MAIL_FROM                           Sender email address
#   MAIL_TOKEN                          Mailtrap (or SMTP provider) API token
#   SWAGGER_DOC_USER                    Swagger basic-auth username
#   SWAGGER_DOC_PASS                    Swagger basic-auth password
#   MAX_LOGIN_ATTEMPTS                  (optional, default 3)
#   OTP_EXPIRY_MINUTES                  (optional, default 5)
#   JWT_ACCESS_TOKEN_EXPIRATION         (optional, default 1h)
#   JWT_REFRESH_TOKEN_EXPIRATION        (optional, default 1d)
#   JWT_OTP_TOKEN_EXPIRATION            (optional, default 60m)
#
#   RENDER_DEPLOY_HOOK_API_GATEWAY          Render deploy hook URL
#   RENDER_DEPLOY_HOOK_AUTH_SERVICE         Render deploy hook URL
#   RENDER_DEPLOY_HOOK_NOTIFICATION_SERVICE Render deploy hook URL
#   RENDER_DEPLOY_HOOK_PAYMENT_SERVICE      Render deploy hook URL
